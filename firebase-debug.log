[debug] [2026-06-24T18:23:07.250Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/michwar-bfcca/rulesets {"name":"projects/michwar-bfcca/rulesets/c9a31fdc-86c7-452a-a7a9-e4dc5f1aa590","source":{"files":[{"content":"rules_version = '2';\n\n// =============================================================================\n// MICHWAR — Firestore Security Rules\n// =============================================================================\n// Guiding principles:\n//  1. ALL financial fields (walletBalance, commissionRate, commissionTier,\n//     driverShareRate, ridesCompleted, ratingAverage/ratingCount, fare,\n//     status transitions on `rides`, transaction ledgers, loyalty points)\n//     are written EXCLUSIVELY by Cloud Functions using the Admin SDK, which\n//     bypasses these rules entirely. Clients therefore never get direct\n//     write access to those fields.\n//  2. Reads are scoped to the user's own data, or to the participants of a\n//     ride (passenger + assigned driver).\n//  3. `live_shares/{token}` is intentionally readable by anyone holding the\n//     token (unauthenticated), so a passenger can share a live-tracking link\n//     with a contact who doesn't have the app — but only while unexpired.\n// =============================================================================\n\nfunction isSignedIn() {\n  return request.auth != null;\n}\n\nfunction isOwner(uid) {\n  return isSignedIn() && request.auth.uid == uid;\n}\n\nfunction isAdmin() {\n  return isSignedIn() &&\n    exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\n    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n}\n\n// Only the listed top-level keys may be present in the diff between the\n// existing document and the proposed write. Used to whitelist the narrow\n// set of self-service fields a user/driver may edit directly.\nfunction onlyAffectsKeys(allowedKeys) {\n  return request.resource.data.diff(resource.data).affectedKeys()\n    .hasOnly(allowedKeys);\n}\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // -------------------------------------------------------------------\n    // users/{uid}\n    // -------------------------------------------------------------------\n    match /users/{uid} {\n      allow read: if isOwner(uid) || isAdmin();\n\n      // Account creation happens via Cloud Function trigger on Auth user\n      // creation in most setups, but we also allow the client to create its\n      // own profile document on first sign-in.\n      allow create: if isOwner(uid) &&\n        request.resource.data.uid == uid &&\n        (!('role' in request.resource.data) || request.resource.data.role in ['passenger', 'driver']);\n\n      // Self-service profile edits: name/email/preferences/saved\n      // places/SOS contacts/FCM tokens. `loyalty` (points/tier) and `role`\n      // are NEVER client-writable — only Cloud Functions (completeRide,\n      // admin tools) may change them.\n      allow update: if isOwner(uid) &&\n        onlyAffectsKeys([\n          'fullName', 'email', 'photoUrl', 'savedPlaces', 'sosContacts',\n          'fcmTokens', 'preferences', 'updatedAt'\n        ]);\n\n      allow delete: if false;\n    }\n\n    // -------------------------------------------------------------------\n    // drivers/{uid}\n    // -------------------------------------------------------------------\n    match /drivers/{uid} {\n      // Driver profiles are readable by any signed-in user — passengers\n      // need to display the matched driver's name/vehicle/rating, and the\n      // demand-matching UI reads aggregate driver state. Wallet balance is\n      // a placeholder/demo figure, not real money.\n      allow read: if isSignedIn();\n\n      allow create: if isOwner(uid) && request.resource.data.uid == uid;\n\n      // Self-service fields only: presence/availability toggle, live\n      // location ping, Heading-Home preference, and verification document\n      // uploads. Financial/performance fields\n      // (walletBalance, commissionTier, commissionRate, driverShareRate,\n      // ridesCompleted, ratingAverage, ratingCount, isOnTrip) are\n      // Cloud-Functions-only.\n      allow update: if isOwner(uid) &&\n        onlyAffectsKeys([\n          'isOnline', 'location', 'headingHome', 'vehicle',\n          'verification', 'fcmTokens', 'updatedAt'\n        ]);\n\n      allow delete: if false;\n    }\n\n    // -------------------------------------------------------------------\n    // rides/{rideId}\n    // -------------------------------------------------------------------\n    match /rides/{rideId} {\n      allow read: if isSignedIn() &&\n        (resource.data.passengerId == request.auth.uid ||\n         resource.data.driverId == request.auth.uid ||\n         isAdmin());\n\n      // The passenger creates the initial ride-request document directly;\n      // the `onRideRequestCreated` trigger then performs driver matching.\n      allow create: if isSignedIn() &&\n        request.resource.data.passengerId == request.auth.uid &&\n        request.resource.data.status == 'searching' &&\n        request.resource.data.driverId == null;\n\n      // Every subsequent state transition (accepted, arrived, ongoing,\n      // cancelled, completed, fare, rating, candidateDriverIds, live-share\n      // tokens) is written exclusively by Cloud Functions via the Admin SDK.\n      allow update: if false;\n      allow delete: if false;\n\n      // Server-maintained audit trail of status transitions.\n      match /status_history/{entryId} {\n        allow read: if isSignedIn() &&\n          (get(/databases/$(database)/documents/rides/$(rideId)).data.passengerId == request.auth.uid ||\n           get(/databases/$(database)/documents/rides/$(rideId)).data.driverId == request.auth.uid ||\n           isAdmin());\n        allow write: if false;\n      }\n    }\n\n    // -------------------------------------------------------------------\n    // wallets/{driverId} and wallets/{driverId}/transactions/{txId}\n    // -------------------------------------------------------------------\n    match /wallets/{driverId} {\n      allow read: if isOwner(driverId) || isAdmin();\n      allow write: if false; // topUpWallet / completeRide (Cloud Functions)\n\n      match /transactions/{txId} {\n        allow read: if isOwner(driverId) || isAdmin();\n        allow write: if false;\n      }\n    }\n\n    // -------------------------------------------------------------------\n    // transactions/{txId}  (reserved top-level collection, unused by the\n    // current client — ledger entries live under wallets/{driverId}/transactions)\n    // -------------------------------------------------------------------\n    match /transactions/{txId} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n\n    // -------------------------------------------------------------------\n    // sos_alerts/{alertId} — written only by the `sosAlert` Cloud Function.\n    // -------------------------------------------------------------------\n    match /sos_alerts/{alertId} {\n      allow read: if isAdmin() ||\n        (isSignedIn() && resource.data.userId == request.auth.uid);\n      allow write: if false;\n    }\n\n    // -------------------------------------------------------------------\n    // live_shares/{token} — public, time-limited read for the live trip\n    // share page (no auth required). Created only by\n    // `generateLiveShareLink` (Cloud Function).\n    // -------------------------------------------------------------------\n    match /live_shares/{token} {\n      allow read: if resource.data.expiresAt > request.time;\n      allow write: if false;\n    }\n\n    // -------------------------------------------------------------------\n    // heatmap_cells/{geohash} — demand heatmap. Any signed-in user may\n    // record a \"demand ping\" (increment count) when requesting a ride;\n    // drivers read the aggregate to find busy areas.\n    // -------------------------------------------------------------------\n    match /heatmap_cells/{cellId} {\n      allow read: if isSignedIn();\n      allow create: if isSignedIn() &&\n        request.resource.data.keys().hasOnly(['geohash', 'lat', 'lng', 'count', 'updatedAt']);\n      allow update: if isSignedIn() &&\n        onlyAffectsKeys(['count', 'updatedAt']);\n      allow delete: if false;\n    }\n\n    // -------------------------------------------------------------------\n    // wallet_transactions/{txId} — top-level ledger (mirrors subcollection\n    // under wallets). Written only by Cloud Functions (Admin SDK).\n    // -------------------------------------------------------------------\n    match /wallet_transactions/{txId} {\n      allow read: if isSignedIn() &&\n        (resource.data.driverId == request.auth.uid || isAdmin());\n      allow write: if false;\n    }\n\n    // -------------------------------------------------------------------\n    // rate_limits/{ipHash} — used by signup rate-limiting Cloud Function.\n    // Clients never read or write this directly.\n    // -------------------------------------------------------------------\n    match /rate_limits/{docId} {\n      allow read, write: if false;\n    }\n\n    // -------------------------------------------------------------------\n    // ratings/{ratingId} — reserved top-level collection, unused by the\n    // current client (ratings are embedded in rides/{rideId}.rating and\n    // written by the `submitRating` Cloud Function).\n    // -------------------------------------------------------------------\n    match /ratings/{ratingId} {\n      allow read: if isAdmin();\n      allow write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-24T18:23:07.884703Z","metadata":{"services":["cloud.firestore"]}}
