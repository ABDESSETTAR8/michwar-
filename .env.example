# ---------------------------------------------------------------------------
# MICHWAR — Environment Configuration Template
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to version control.
# ---------------------------------------------------------------------------

# Google Maps SDK (Android / iOS / Web) — Maps, Directions, Distance Matrix APIs
GOOGLE_MAPS_API_KEY_ANDROID=YOUR_ANDROID_MAPS_API_KEY
GOOGLE_MAPS_API_KEY_IOS=YOUR_IOS_MAPS_API_KEY
GOOGLE_MAPS_API_KEY_WEB=YOUR_WEB_MAPS_API_KEY

# Firebase project
FIREBASE_PROJECT_ID=michwar-prod
FIREBASE_WEB_API_KEY=YOUR_FIREBASE_WEB_API_KEY
FIREBASE_APP_ID_ANDROID=YOUR_FIREBASE_ANDROID_APP_ID
FIREBASE_APP_ID_IOS=YOUR_FIREBASE_IOS_APP_ID
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID

# Live trip sharing — base URL of the hosted web tracker (Firebase Hosting)
LIVE_SHARE_BASE_URL=https://michwar-prod.web.app/track
