<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows plain-HTTP (cleartext) traffic to the Firebase Local Emulator
  Suite, which Android 9+ blocks by default. 10.0.2.2 is the special
  alias the Android emulator uses to reach the host machine's localhost
  (see lib/main.dart _connectToEmulators).

  This file only affects DEBUG builds (see debug/AndroidManifest.xml) and
  must not be referenced from a release build.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
